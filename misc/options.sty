% 2. CREATE A SWITCH to turn the feature on or off.
\newif\ifrandombackgrounds
\randombackgroundsfalse % Default is OFF.

% 3. CREATE COMMANDS to turn the backgrounds on and off.
\newcommand{\StartRandomBackgrounds}{\randombackgroundstrue}
\newcommand{\StopRandomBackgrounds}{\randombackgroundsfalse}

% 4. CREATE THE COMMAND that draws one random background.
\newcommand{\DrawRandomPageBackground}{%
  \ifrandombackgrounds
    % Reseed the random generator on every page
    % using the page number. This guarantees a different "random"
    % choice for each page.
    \pgfmathsetseed{\value{page}}

    \pgfmathrandomitem{\myrandomimage}{pagebackgrounds}% Select a random image from the list
    \begin{tikzpicture}[remember picture, overlay]
      \node[at=(current page.center), inner sep=0, opacity=0.15] {
        \expandafter\includegraphics\expandafter[
          width=\paperwidth,
          height=\paperheight
        ]{\myrandomimage}
      };
    \end{tikzpicture}%
  \fi
}

