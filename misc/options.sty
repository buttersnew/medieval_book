% Page size
% --- DYNAMIC PAGE LAYOUT ENGINE ---
\ifprintversion
  % --- OUTPUT: FINAL PRINT PDF ---
  % Bleed and gutter margins are mandatory for printing.
  \usepackage[
      paperheight=9in,
      paperwidth=6in,
      bleed=0.125in, % Adds 1/8 inch bleed margin
      top=0.75in,
      bottom=0.75in,
      outer=0.75in,
      inner=0.875in
  ]{geometry}
  \usepackage[center,cam]{crop} % Adds printer's crop marks

\else
  % --- OUTPUT: DIGITAL PDF (NO BLEED OR CROP MARKS) ---
  \ifboundversion
    % --- MODE: BOUND PREVIEW ---
    % Asymmetrical "gutter" margins for a realistic preview of the bound book.
    \usepackage[
        paperheight=9in,
        paperwidth=6in,
        top=0.75in,
        bottom=0.75in,
        outer=0.75in,
        inner=0.875in
    ]{geometry}
  \else
    % --- MODE: SIMPLE SYMMETRICAL ---
    % Symmetrical margins for easy screen reading.
    % The horizontal margin (0.8125in) is the average of the inner and outer margins
    % to keep the text block width consistent.
    \usepackage[
        paperheight=9in,
        paperwidth=6in,
        top=0.75in,
        bottom=0.75in,
        hmargin=0.8125in % Sets left and right margins to be equal
    ]{geometry}
  \fi
\fi

