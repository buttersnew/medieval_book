% --- Chapter Image Setup ---
\usepackage{etoolbox}

% --- Chapter Background Setup (Definitive "Redefinition" Method) ---

\newcommand{\chapterTextColor}{black}

\newcommand{\drawchapterbackground}{}

\newcommand{\setchapterbackground}[2]{%
  \renewcommand{\drawchapterbackground}{%
    \begin{tikzpicture}[remember picture, overlay]
      \node[at=(current page.center), inner sep=0] {
        \includegraphics[width=\paperwidth, height=\paperheight]{#1}
      };
    \end{tikzpicture}%
  }%
  \renewcommand{\chapterTextColor}{#2}%
}

\titleformat{\chapter}[block]
  {\normalfont\carolingian\huge\centering\color{\chapterTextColor}}
  {\thechapter\\}
  {0pt}
  {
    \drawchapterbackground
    \gdef\drawchapterbackground{}
    \gdef\chapterTextColor{black}
  }

% Format for \section
\titleformat{\section}[block]
  {\normalfont\carolingian\Large\centering}
  {\thesection}
  {1em}
  {}

% Format for \subsection
\titleformat{\subsection}[block]
  {\normalfont\carolingian\large}
  {\thesubsection}
  {1em}
  {}
  []

\newcommand{\sectionbreak}{\clearpage}

